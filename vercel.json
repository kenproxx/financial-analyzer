{
  "rewrites": [
    {
      "source": "/api/yahoo/:path*",
      "destination": "https://query1.finance.yahoo.com/:path*"
    },
    {
      "source": "/api/binance/:path*",
      "destination": "https://api.binance.com/:path*"
    },
    {
      "source": "/api/alpha",
      "destination": "https://www.alphavantage.co/"
    }
  ],
  "crons": [
    {
      "path": "/api/sync-history",
      "schedule": "0 1 * * *"
    }
  ]
}
